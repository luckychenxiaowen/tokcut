# tokcut Environment Variables Template
# Copy this file to .env and fill in your values

# Server Configuration
TOKCUT_HOST=0.0.0.0
TOKCUT_PORT=8800
TOKCUT_LOG_LEVEL=info
TOKCUT_CONFIG_PATH=config/default.yaml

# API Keys for benchmarking (optional)
# DEEPSEEK_API_KEY=sk-xxxx
# GLM_API_KEY=xxxx
# MINIMAX_API_KEY=xxxx
# HUNYUAN_API_KEY=xxxx
# MOONSHOT_API_KEY=xxxx
